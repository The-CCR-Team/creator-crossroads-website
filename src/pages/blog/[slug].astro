---
import { Client } from "@notionhq/client";
import { wrapLists, getNotionFileUrl } from "../../notion"; 

import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Stars from "../../components/StarDivider.astro";
import Particles from "../../components/Particles.astro";

import blueskyIcon from "../../assets/icons/bluesky-icon.png";
import blueskyAltIcon from "../../assets/icons/bluesky-alt-icon.png";
import twitterIcon from "../../assets/icons/twitter-icon.png";
import twitterAltIcon from "../../assets/icons/twitter-alt-icon.png";
import emailIcon from "../../assets/icons/email-icon.png";
import emailAltIcon from "../../assets/icons/email-alt-icon.png";
import linkIcon from "../../assets/icons/link-icon.png";
import linkAltIcon from "../../assets/icons/link-alt-icon.png";
import calendarIcon from "../../assets/icons/calendar-icon.png";
import calendarAltIcon from "../../assets/icons/calendar-alt-icon.png";

export const prerender = false;

const notionKey = import.meta.env.NOTION_KEY;
const databaseId = import.meta.env.DB_ID || "";
const notion = new Client({ auth: notionKey });

const { slug } = Astro.params;
const normalizedSlug = (slug || "").trim().toLowerCase();

const response = await notion.dataSources.query({
  data_source_id: databaseId,
  filter: { 
    and: [
      { property: "Slug", rich_text: { equals: normalizedSlug } },
      { property: "Published", checkbox: { equals: true } }
    ]
  },
});

const pageData = response.results[0] as any;
let post: any = null;

if (pageData?.properties) {
  const blocks = await notion.blocks.children.list({ block_id: pageData.id });
  const props = pageData.properties;

  post = {
    title: props.Title?.title?.[0]?.plain_text || "Untitled Post",
    publication_date: props.PublicationDate?.date?.start || "",
    cover: getNotionFileUrl(props.Cover?.files?.[0]),
    content: wrapLists(blocks.results),
    authors: props.Authors?.people?.map((author: any) => ({
      name: author.name || "Anonymous",
      avatar: author.avatar_url || null,
    })) || [],
  };
}

if (!post) {
  return Astro.redirect('/404');
}

const pageTitle = post.title;
const pageDescription = post.title || "Blog Post";
const pageUrl = String(Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body>
    <Particles />
    <Header />

    <main class="page-container">
      <div class="navigation-wrapper">
        <a href="/blog" class="back-link">Back to Blog Posts</a>
      </div>
      
      <article class="blog-card">
        <div class="blog-header-content">
          <h1 class="blog-title">{post.title}</h1>

          <div class="blog-meta-row">
            {post.authors.length > 0 && (
              <div class="meta-item authors-badge">
                {post.authors.map((author: any) => (
                  <span class="author-pill">
                    {author.avatar ? (
                      <img src={author.avatar} alt={author.name} class="author-avatar" />
                    ) : (
                      <span class="author-fallback">👤</span>
                    )}
                    {author.name}
                  </span>
                ))}
              </div>
            )}

            <div class="meta-item date-badge">
              <span class="calendar-icon-wrap">
                <img class="cal-icon cal-default" src={calendarIcon.src} alt="Date" />
                <img class="cal-icon cal-alt" src={calendarAltIcon.src} alt="Date" />
              </span>
              <span class="date-text">{post.publication_date || "N/A"}</span>
            </div>
          </div>

          <div class="share-row">
            <a href={`https://bsky.app/intent/compose?text=${encodeURIComponent(post.title + ' ' + pageUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
              <img class="share-icon share-default" src={blueskyIcon.src} alt="Share on Bluesky" />
              <img class="share-icon share-alt" src={blueskyAltIcon.src} alt="Share on Bluesky" />
            </a>
            <a href={`https://x.com/intent/tweet?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
              <img class="share-icon share-default" src={twitterIcon.src} alt="Share on Twitter" />
              <img class="share-icon share-alt" src={twitterAltIcon.src} alt="Share on Twitter" />
            </a>
            <a href={`mailto:?subject=${encodeURIComponent(post.title)}&body=${encodeURIComponent(pageUrl)}`} class="share-btn">
              <img class="share-icon share-default" src={emailIcon.src} alt="Share via Email" />
              <img class="share-icon share-alt" src={emailAltIcon.src} alt="Share via Email" />
            </a>
            <button id="copy-link-btn" class="share-btn" data-url={pageUrl}>
              <img class="share-icon share-default" src={linkIcon.src} alt="Copy Link" />
              <img class="share-icon share-alt" src={linkAltIcon.src} alt="Copy Link" />
            </button>
          </div>
        </div>

        {post.cover && (
          <div class="blog-cover-wrapper">
            <img src={post.cover} alt={post.title} class="blog-cover-img" />
          </div>
        )}

        <div class="divider-space">
          <Stars />
        </div>

        <div class="blog-body-markdown" set:html={post.content} />

        <div class="share-bottom">
          <div class="divider-space">
            <Stars />
          </div>
          <p class="share-label">Share our article:</p>
          <div class="share-row">
            <a href={`https://bsky.app/intent/compose?text=${encodeURIComponent(post.title + ' ' + pageUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
              <img class="share-icon share-default" src={blueskyIcon.src} alt="Share on Bluesky" />
              <img class="share-icon share-alt" src={blueskyAltIcon.src} alt="Share on Bluesky" />
            </a>
            <a href={`https://x.com/intent/tweet?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
              <img class="share-icon share-default" src={twitterIcon.src} alt="Share on Twitter" />
              <img class="share-icon share-alt" src={twitterAltIcon.src} alt="Share on Twitter" />
            </a>
            <a href={`mailto:?subject=${encodeURIComponent(post.title)}&body=${encodeURIComponent(pageUrl)}`} class="share-btn">
              <img class="share-icon share-default" src={emailIcon.src} alt="Share via Email" />
              <img class="share-icon share-alt" src={emailAltIcon.src} alt="Share via Email" />
            </a>
            <button id="copy-link-btn-bottom" class="share-btn" data-url={pageUrl}>
              <img class="share-icon share-default" src={linkIcon.src} alt="Copy Link" />
              <img class="share-icon share-alt" src={linkAltIcon.src} alt="Copy Link" />
            </button>
          </div>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 8rem 1.5rem;
    font-family: 'Baloo', sans-serif;
  }

  .blog-card {
    background: rgba(0, 3, 77, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--accent-dark);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    overflow: hidden;
    padding: 3.5rem 4rem;
    font-family: 'Baloo', sans-serif;
  }

  @media (max-width: 768px) {
    .blog-card {
      padding: 2rem 1.75rem;
    }
  }

  .blog-cover-wrapper {
    width: 100%;
    margin-top: 1rem;
    margin-bottom: 3rem;
    border-radius: 8px;
    overflow: hidden;
  }

  .blog-cover-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .navigation-wrapper {
    margin-bottom: 1.75rem;
  }

  .back-link {
    color: #ffffff !important;
    opacity: 0.85;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    transition: all 0.25s ease;
    font-family: 'Baloo', sans-serif;
  }

  .back-link::before {
    content: "";
    display: inline-block;
    width: 7px;
    height: 7px;
    border-left: 2.5px solid currentColor;
    border-bottom: 2.5px solid currentColor;
    transform: rotate(45deg);
    margin-top: 1px;
    transition: transform 0.25s ease;
  }

  .back-link:hover {
    opacity: 1;
    transform: translateX(-4px);
  }

  .back-link:hover::before {
    transform: translateX(-2px) rotate(45deg);
  }

  .blog-header-content {
    margin-bottom: 2rem;
  }

  .blog-title {
    font-size: 3.2rem;
    color: #ffffff;
    margin-bottom: 1rem;
    font-family: 'Baloo', sans-serif;
  }

  .blog-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
    color: #ffffff;
    opacity: 0.8;
    font-family: 'Baloo', sans-serif;
  }

  /* author pill */
  .author-pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .author-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    transform: none;
  }

  .author-avatar:hover {
    transform: scale(1.2) !important;
    box-shadow: 0 0 0 2px white;
  }

  /* calendar icon */
  .date-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .calendar-icon-wrap {
    position: relative;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    overflow: visible;
    transition: transform 0.2s ease;
    cursor: default;
  }

  .calendar-icon-wrap:hover {
    transform: scale(1.2);
  }

  .cal-icon {
    position: absolute;
    border-radius: 0px;
    inset: 0;
    width: 24px;
    height: 24px;
    object-fit: contain;
    transition: opacity 0.2s ease;
    transform: none !important;
  }

  .cal-alt { opacity: 0; }
  .calendar-icon-wrap:hover .cal-default { opacity: 0; }
  .calendar-icon-wrap:hover .cal-alt { opacity: 1; }

  .date-text {
    font-family: 'Baloo', sans-serif;
  }

  /* share buttons */
  .share-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.25rem;
  }

  .share-btn {
    position: relative;
    width: 48px;
    height: 48px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .share-btn:hover {
    transform: scale(1.2);
  }

  .share-icon {
    position: absolute;
    width: 48px;
    height: 48px;
    object-fit: contain;
    transition: opacity 0.2s ease;
    transform: none !important;
  }

  .share-alt { opacity: 0; }
  .share-btn:hover .share-default { opacity: 0; }
  .share-btn:hover .share-alt { opacity: 1; }

  /* bottom share section */
  .share-bottom {
    margin-top: 3rem;
  }

  .share-label {
    font-family: 'Baloo', sans-serif;
    font-size: 1.8rem;
    color: white;
    margin-bottom: 0.5rem;
  }

  .divider-space {
    margin: 2rem 0;
  }

  .blog-body-markdown {
    font-family: 'Baloo', sans-serif;
  }
</style>

<script>
  function hookCopyBtn(id: string) {
    const btn = document.getElementById(id);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url');
      if (url) {
        navigator.clipboard.writeText(url).catch(console.error);
      }
    });
  }

  hookCopyBtn('copy-link-btn');
  hookCopyBtn('copy-link-btn-bottom');
</script>