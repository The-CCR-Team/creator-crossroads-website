---
const today = new Date();
import { Image } from "astro:assets";
import DiscordIcon from "../assets/icons/discord-icon.png";
import DiscordIconAlt from "../assets/icons/discord-alt-icon.png";
import BlueskyIcon from "../assets/icons/bluesky-icon.png";
import BlueskyIconAlt from "../assets/icons/bluesky-alt-icon.png";
import TwitterIcon from "../assets/icons/twitter-icon.png";
import TwitterIconAlt from "../assets/icons/twitter-alt-icon.png";
import YoutubeIcon from "../assets/icons/youtube-icon.png";
import YoutubeIconAlt from "../assets/icons/youtube-alt-icon.png";
import EmailIcon from "../assets/icons/email-icon.png";
import EmailIconAlt from "../assets/icons/email-alt-icon.png";
---
<footer>
  {today.getFullYear()} Creator CrossRoads
  <div class="social-links">
    <a class="social-link" href="mailto:contact@creatorcrossroads.team" target="_blank" rel="noopener noreferrer">
      <span class="sr-only">Join our Discord</span>
      <Image src={EmailIcon} alt="" class="icon icon-closed" width={64} height={64} />
      <Image src={EmailIconAlt} alt="" class="icon icon-open" width={64} height={64} />
    </a>
    <a class="social-link" href="https://discord.gg/zzRy2hjppe" target="_blank" rel="noopener noreferrer">
      <span class="sr-only">Join our Discord</span>
      <Image src={DiscordIcon} alt="" class="icon icon-closed" width={64} height={64} />
      <Image src={DiscordIconAlt} alt="" class="icon icon-open" width={64} height={64} />
    </a>
    <a class="social-link" href="https://bsky.app/profile/creatorcrossroads.team" target="_blank" rel="noopener noreferrer">
      <span class="sr-only">Follow our Bluesky</span>
      <Image src={BlueskyIcon} alt="" class="icon icon-closed" width={64} height={64} />
      <Image src={BlueskyIconAlt} alt="" class="icon icon-open" width={64} height={64} />
    </a>
    <a class="social-link" href="https://x.com/TheCCRteam" target="_blank" rel="noopener noreferrer">
      <span class="sr-only">Follow our Twitter</span>
      <Image src={TwitterIcon} alt="" class="icon icon-closed" width={64} height={64} />
      <Image src={TwitterIconAlt} alt="" class="icon icon-open" width={64} height={64} />
    </a>
    <a class="social-link" href="https://www.youtube.com/@CreatorCrossroads" target="_blank" rel="noopener noreferrer">
      <span class="sr-only">Subscribe to our YouTube</span>
      <Image src={YoutubeIcon} alt="" class="icon icon-closed" width={64} height={64} />
      <Image src={YoutubeIconAlt} alt="" class="icon icon-open" width={64} height={64} />
    </a>
  </div>
</footer>

<style>
	footer {
        padding: 1em;
        text-align: center;
        background: rgba(0, 3, 77, 0.25);
        border-radius: 16px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(0, 3, 77, 0.25);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    text-decoration: none;
  }

  .icon {
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .icon-closed {
    opacity: 1;
    transform: scale(1);
  }

  .icon-open {
    opacity: 0;
    transform: scale(0.9);
  }

  .social-link:hover .icon-closed {
    opacity: 0;
    transform: scale(0.9);
  }

  .social-link:hover .icon-open {
    opacity: 1;
    transform: scale(1.15);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>